{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "functions": {
  "api/**/*.php": {
    "runtime": "vercel-php@0.8.0"
  }
},
    "routes": [
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://gki-darmo-permai.vercel.app",
        "APP_KEY": "base64:mLxw1W4noSe9jLV/NJDVyBtwfa9jncdGmFzcPLMvnOg=",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie"
    }
}